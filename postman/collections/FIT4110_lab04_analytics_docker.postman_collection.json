                "exec": [
                  "pm.test(\"Status code is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"Response is ProblemDetails\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status').to.equal(401);",
                  "});"
