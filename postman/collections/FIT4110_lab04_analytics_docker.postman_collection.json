{
  "info": {
    "_postman_id": "analytics-lab04-collection",
    "name": "FIT4110 Lab 04 - Analytics Service",
    "description": "Postman collection for testing Analytics Service Docker container",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
